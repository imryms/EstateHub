<%- include('../partials/header.ejs') %>

<div class="container">
  <h2>List a New Property</h2>

  <form action="/properties" method="POST">
    <div>
      <label for="title">Title:</label>
      <input
        type="text"
        name="title"
        id="title"
        placeholder="e.g. Modern City Apartment"
        required
      />
    </div>

    <div>
      <label for="description">Description:</label>
      <textarea
        name="description"
        id="description"
        placeholder="Describe the property..."
      ></textarea>
    </div>

    <div>
      <label for="type">Property Type:</label>
      <select name="type" id="type" required>
        <option value="" disabled selected>Select a type</option>
        <option value="Apartment">Apartment</option>
        <option value="House">House</option>
        <option value="Studio">Studio</option>
        <option value="Villa">Villa</option>
      </select>
    </div>

    <div>
      <label>Purpose:</label>
      <input type="radio" name="purpose" value="sale" id="sale" checked />
      <label for="sale">For Sale</label>
      <input type="radio" name="purpose" value="rent" id="rent" />
      <label for="rent">For Rent</label>
    </div>

    <div>
      <label for="price">Price:</label>
      <input
        type="number"
        name="price"
        id="price"
        min="0"
        placeholder="0.00"
        required
      />
    </div>

    <div>
      <label for="address">Address:</label>
      <input
        type="text"
        name="address"
        id="address"
        placeholder="123 Main St, City"
        required
      />
    </div>

    <div>
      <label for="images">Image URL:</label>
      <input
        type="text"
        name="images"
        id="images"
        placeholder="https://link-to-image.jpg"
      />
    </div>

    <button type="submit">Create Listing</button>
  </form>
</div>

<%- include('../partials/footer.ejs') %>
