<%- include('../partials/header.ejs') %>

<div class="property-container">
  <a href="/properties" class="cta-secondary"> Back to Listings</a>

  <article class="profile-card" style="margin-top: 20px;">
    <span class="hero-badge"><%= property.status %></span>
    <h1><%= property.title %></h1>

    <p>Status: <strong><%= property.status.toUpperCase() %></strong></p>

    <% if (property.images.length > 0) { %>
        <img src="<%= property.images[0] %>" class="property-hero-img">
    <% } %>

    <div class="meta-info">
      <p><strong>Price:</strong> $<%= property.price.toLocaleString() %></p>
      <p><strong>Type:</strong> <%= property.type %></p>
      <p><strong>Location:</strong> <%= property.address %></p>
    </div>
      <hr />
<p style="font-size: 1.1rem; line-height: 1.6;"><%= property.description %></p>
<p><small>Listed on: <%= property.createdAt.toDateString() %></small></p>
    </div>

    <% if (user && user.role === "client") { %>
    <div class="book-now">
    <a href="/appointments/<%= property._id %>/new" class="book-now-button">
      Book Appointment
    </a>
    </div>
    <% } %>

    <% if (user && user._id === property.ownerId.toString()) { %>
    <a href="/properties/<%= property._id %>/edit" class="cta-secondary">Edit</a>
    <a href="/properties/<%= property._id %>/edit">Edit Property</a>

    <form action="/properties/<%= property._id %>?_method=PUT" method="POST">
      <input type="hidden" name="status" value="<%= property.status === 'active' ? 'paused' : 'active' %>">
      <button type="submit">
        <%= property.status === 'active' ? 'Pause' : 'Activate' %>
      </button>
    </form>

    <form action="/properties/<%= property._id %>?_method=DELETE" method="POST">
      <button type="submit" style="color: red;">Delete Property</button>
    </form>

  </div>
<% } %>
  </article>
</div>

<%- include('../partials/footer.ejs') %>
