<%- include('../partials/header.ejs') %>

<main class="signup-page">
  <h2 class="signup-title">Sign Up</h2>

  <div class="signup-box">
    <form action="/auth/sign-up" method="POST" class="signup-form">

      <input type="text" name="name" placeholder="Name" required class="signup-input" />

      <input type="email" name="email" placeholder="Email" required class="signup-input" />

      <input type="tel" name="phoneNumber" placeholder="Phone Number" required class="signup-input" />

      <div class="role-group">
        <label>Role:</label>
        <label><input type="radio" name="role" value="client" checked /> Client</label>
        <label><input type="radio" name="role" value="owner" /> Owner</label>
      </div>

      <input type="password" name="password" placeholder="Password" required class="signup-input" />

      <input type="password" name="confirmPassword" placeholder="Confirm Password" required class="signup-input" />

      <button type="submit" class="signup-submit">Sign Up</button>

    </form>
  </div>
</main>

<%- include('../partials/footer.ejs') %>
